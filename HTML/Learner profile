<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Learner Profile</title>
    <link rel="stylesheet" href="profile_learner.css">
</head>
<body>
    <div class="form-container">
        <h1>Learner Profile</h1>
        
        <form>
            <!-- Name -->
            <div class="form-group">
                <label for="learner-name">Your Name:</label>
                <input type="text" id="learner-name" name="learner-name" required>
            </div>
            
            <!-- Email -->
            <div class="form-group">
                <label for="learner-email">Your Email:</label>
                <input type="email" id="learner-email" name="learner-email" required>
            </div>
            
            <!-- Phone Number -->
            <div class="form-group">
                <label for="phone-number">Your Phone Number:</label>
                <input type="tel" id="phone-number" name="phone-number" required>
            </div>
            
            <!-- About Me -->
            <div class="form-group">
                <label for="about-me">About Me:</label>
                <textarea id="about-me" name="about-me" rows="4" required></textarea>
            </div>
            
            <!-- Country -->
            <div class="form-group">
                <label for="country">Country:</label>
                <input type="text" id="country" name="country" required>
            </div>
            
            <!-- Password -->
            <div class="form-group">
                <label for="password">Password:</label>
                <input type="password" id="password" name="password" required>
            </div>
            
            <!-- Change Password -->
            <div class="form-group">
                <label for="change-password">Change Password:</label>
                <input type="password" id="change-password" name="change-password">
            </div>
            
            <!-- Submit Button -->
            <input type="submit" value="Submit">
        </form>
    </div>
</body>
</html>
